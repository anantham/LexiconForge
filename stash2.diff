+// Browser-compatible EPUB generation using JSZip
+interface BrowserEpubOptions {
+  title: string;
+  author: string;
+  description: string;
+  chapters: Array<{ title: string; content: string; filename?: string; }>;
+  css?: string;
+  date?: string;
+  language?: string;
+}
+
+// Enhanced browser EPUB generation interface
+interface BrowserEpubOptions {
+  title: string;
+  author: string;
+  description: string;
+  chapters: Array<{ title: string; content: string; filename?: string; }>;
+  css?: string;
+  date?: string;
+  language?: string;
+  novelConfig?: NovelConfig;
+}
+
+async function generateBrowserEpub(options: BrowserEpubOptions): Promise<ArrayBuffer> {
+  const zip = new JSZip();
+  const uuid = options.novelConfig?.isbn || ('urn:uuid:' + generateUUID());
+  
+  // Create META-INF directory
+  zip.folder('META-INF');
+  zip.file('META-INF/container.xml', `<?xml version="1.0" encoding="UTF-8"?>
+<container version="1.0" xmlns="urn:oasis:names:tc:opendocument:xmlns:container">
+  <rootfiles>
+    <rootfile full-path="OEBPS/content.opf" media-type="application/oebps-package+xml"/>
+  </rootfiles>
+</container>`);
+
+  // Create OEBPS directory
+  const oebps = zip.folder('OEBPS');
+  
+  // Create content.opf (package file)
+  const manifestItems = options.chapters.map((_, index) => 
+    `    <item id="ch${index + 1}" href="chapter${index + 1}.xhtml" media-type="application/xhtml+xml"/>`
+  ).join('\n');
+  
+  const spineItems = options.chapters.map((_, index) => 
+    `    <itemref idref="ch${index + 1}"/>`
+  ).join('\n');
+
+  // Build comprehensive metadata using novel configuration
+  const config = options.novelConfig;
+  let metadataXml = `    <dc:identifier id="bookid">${uuid}</dc:identifier>
+    <dc:title>${escapeXml(options.title)}</dc:title>
+    <dc:creator>${escapeXml(options.author)}</dc:creator>
+    <dc:description>${escapeXml(options.description)}</dc:description>
+    <dc:language>${options.language || 'en'}</dc:language>
+    <dc:date>${options.date || new Date().toISOString().split('T')[0]}</dc:date>
+    <dc:publisher>${escapeXml(config?.publisher || 'LexiconForge')}</dc:publisher>
+    <meta name="generator" content="LexiconForge EPUB Generator"/>`;
+
+  // Add enhanced metadata if available from novel config
+  if (config) {
+    if (config.originalTitle) {
+      metadataXml += `\n    <meta name="original-title" content="${escapeXml(config.originalTitle)}"/>`;
+    }
+    if (config.originalLanguage) {
+      metadataXml += `\n    <dc:language id="original-language">${config.originalLanguage}</dc:language>`;
+    }
+    if (config.genre) {
+      // Split genres and add as separate subjects
+      const genres = config.genre.split(',').map(g => g.trim());
+      genres.forEach(genre => {
+        metadataXml += `\n    <dc:subject>${escapeXml(genre)}</dc:subject>`;
+      });
+    }
+    if (config.seriesName) {
+      metadataXml += `\n    <meta name="calibre:series" content="${escapeXml(config.seriesName)}"/>`;
+      if (config.volumeNumber) {
+        metadataXml += `\n    <meta name="calibre:series_index" content="${config.volumeNumber}"/>`;
+      }
+    }
+    if (config.translationNotes) {
+      metadataXml += `\n    <meta name="translation-notes" content="${escapeXml(config.translationNotes)}"/>`;
+    }
+  }
+
+  oebps!.file('content.opf', `<?xml version="1.0" encoding="UTF-8"?>
+<package xmlns="http://www.idpf.org/2007/opf" unique-identifier="bookid" version="2.0">
+  <metadata xmlns:dc="http://purl.org/dc/elements/1.1/" xmlns:opf="http://www.idpf.org/OPF/spec/2.0/2.1/draft/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
+${metadataXml}
+  </metadata>
+  <manifest>
+    <item id="ncx" href="toc.ncx" media-type="application/x-dtbncx+xml"/>
+${manifestItems}
+${options.css ? '    <item id="css" href="styles.css" media-type="text/css"/>' : ''}
+  </manifest>
+  <spine toc="ncx">
+${spineItems}
+  </spine>
+</package>`);
+
+  // Create table of contents (toc.ncx)
+  const navPoints = options.chapters.map((chapter, index) => `
+    <navPoint id="ch${index + 1}" playOrder="${index + 1}">
+      <navLabel>
+        <text>${escapeXml(chapter.title)}</text>
+      </navLabel>
+      <content src="chapter${index + 1}.xhtml"/>
+    </navPoint>`).join('');
+
+  oebps!.file('toc.ncx', `<?xml version="1.0" encoding="UTF-8"?>
+<ncx xmlns="http://www.daisy.org/z3986/2005/ncx/" version="2005-1">
+  <head>
+    <meta name="dtb:uid" content="${uuid}"/>
+    <meta name="dtb:depth" content="1"/>
+    <meta name="dtb:totalPageCount" content="0"/>
+    <meta name="dtb:maxPageNumber" content="0"/>
+  </head>
+  <docTitle>
+    <text>${escapeXml(options.title)}</text>
+  </docTitle>
+  <navMap>
+${navPoints}
+  </navMap>
+</ncx>`);
+
+  // Add CSS file if provided
+  if (options.css) {
+    oebps!.file('styles.css', options.css);
+  }
+
+  // Create chapter files
+  options.chapters.forEach((chapter, index) => {
+    const cssLink = options.css ? '<link rel="stylesheet" type="text/css" href="styles.css" />' : '';
+    const xhtmlContent = `<?xml version="1.0" encoding="UTF-8"?>
+<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.1//EN" "http://www.w3.org/TR/xhtml11/DTD/xhtml11.dtd">
+<html xmlns="http://www.w3.org/1999/xhtml">
+<head>
+  <title>${escapeXml(chapter.title)}</title>
+  <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
+  ${cssLink}
+</head>
+<body>
+  ${chapter.content}
+</body>
+</html>`;
+    
+    oebps!.file(`chapter${index + 1}.xhtml`, xhtmlContent);
+  });
+
+  // Create mimetype file (must be uncompressed and first in zip)
+  zip.file('mimetype', 'application/epub+zip', { compression: 'STORE' });
+
+  // Generate the zip file
+  return await zip.generateAsync({ 
+    type: 'arraybuffer',
+    compression: 'DEFLATE',
+    compressionOptions: { level: 9 }
+  });
+}
+
+function generateUUID(): string {
+  return 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, function(c) {
+    const r = Math.random() * 16 | 0;
+    const v = c === 'x' ? r : (r & 0x3 | 0x8);
+    return v.toString(16);
+  });
+}
+
+function escapeXml(unsafe: string): string {
+  return unsafe.replace(/[<>&'"]/g, function (c) {
+    switch (c) {
+      case '<': return '&lt;';
+      case '>': return '&gt;';
+      case '&': return '&amp;';
+      case '\'': return '&apos;';
+      case '"': return '&quot;';
+    }
+    return c;
+  });
+}
