+class BookTokiAdapter extends BaseAdapter {
+    extractTitle = () => {
+        const fullTitle = this.doc.querySelector('title')?.textContent ?? '';
+        // Format: "던전 디펜스-2화 | 북토끼 - 웹소설 자료실"
+        // Extract Korean chapter title pattern like "던전 디펜스-2화"
+        const chapterMatch = fullTitle.match(/([^_|]+?-\d+화)/);
+        if (chapterMatch) {
+            return chapterMatch[1].trim();
+        }
+        
+        // Fallback: try h1, h2 elements
+        const h1Title = this.doc.querySelector('h1')?.textContent?.trim();
+        if (h1Title) return h1Title;
+        
+        const h2Title = this.doc.querySelector('h2')?.textContent?.trim();
+        if (h2Title) return h2Title;
+        
+        return fullTitle.split('|')[0].trim() || null;
+    };
+
+    extractContent = () => {
+        // Primary content selector based on BookToki HTML structure
+        const contentContainer = this.doc.querySelector('#novel_content');
+        if (!contentContainer) return null;
+        
+        // Look for content within the f9e99a33513 div (specific to BookToki)
+        let contentDiv = contentContainer.querySelector('div.f9e99a33513');
+        if (!contentDiv) {
+            // Fallback to direct extraction from novel_content
+            contentDiv = contentContainer;
+        }
+        
+        // Extract all paragraph content
+        const paragraphs = contentDiv.querySelectorAll('p');
+        if (!paragraphs.length) {
+            // Fallback to raw text
+            return this.extractRawText(contentDiv);
+        }
+        
+        // Extract and clean paragraph text
+        const validParagraphs: string[] = [];
+        paragraphs.forEach(p => {
+            const text = p.textContent?.trim();
+            if (text && this.isValidParagraph(text)) {
+                validParagraphs.push(text);
+            }
+        });
+        
+        if (!validParagraphs.length) {
+            return this.extractRawText(contentDiv);
+        }
+        
+        const content = validParagraphs.join('\n\n');
+        
+        // Validate content quality
+        if (!this.isValidContent(content)) {
+            return null;
+        }
+        
+        return content;
+    };
+    
+    private extractRawText = (container: Element): string | null => {
+        // Remove script and style elements
+        const clonedContainer = container.cloneNode(true) as Element;
+        clonedContainer.querySelectorAll('script, style').forEach(el => el.remove());
+        
+        const rawText = clonedContainer.textContent?.trim();
+        if (!rawText) return null;
+        
+        // Basic cleanup
+        const lines = rawText.split('\n')
+            .map(line => line.trim())
+            .filter(line => line && this.isValidParagraph(line));
+        
+        const content = lines.join('\n\n');
+        return this.isValidContent(content) ? content : null;
+    };
+    
+    private isValidParagraph = (text: string): boolean => {
+        if (!text || text.length < 3) return false;
+        
+        // Skip separator lines and metadata
+        const invalidPatterns = [
+            /^={5,}/, // Separator lines like "====="
+            /^\d{5}\s/, // Chapter numbers like "00002"
+            /^https?:\/\//, // URLs
+            /^www\./, // Web addresses
+        ];
+        
+        return !invalidPatterns.some(pattern => pattern.test(text.trim()));
+    };
+    
+    private isValidContent = (content: string): boolean => {
+        if (!content || content.length < 500) return false;
+        
+        // Check for Korean text (basic validation)
+        const koreanChars = content.match(/[가-힣]/g);
+        if (!koreanChars || koreanChars.length < 100) return false;
+        
+        // Check content quality indicators  
+        const sentenceIndicators = (content.match(/[.!?다]/g) || []).length;
+        return sentenceIndicators >= 10;
+    };
+    
+    private getLinkByDirection = (isNext: boolean): string | null => {
+        // Look for navigation links
+        const navSelectors = [
+            'a[href*="/novel/"]', // Direct novel links
+            '.btn-group a[href]', // Button group navigation
+            '.pagination a[href]', // Pagination links
+            'a[href*="chapter"]', // Chapter links
+        ];
+        
+        const navLinks: HTMLAnchorElement[] = [];
+        navSelectors.forEach(selector => {
+            const links = this.doc.querySelectorAll(selector) as NodeListOf<HTMLAnchorElement>;
+            navLinks.push(...Array.from(links));
+        });
+        
+        if (!navLinks.length) return null;
+        
+        // Extract current chapter ID from URL
+        const currentChapterId = this.extractChapterIdFromUrl(this.url);
+        if (!currentChapterId) return null;
+        
+        // Filter and analyze navigation links
+        const chapterLinks = navLinks
+            .map(link => {
+                const href = link.getAttribute('href');
+                if (!href || !href.includes('/novel/')) return null;
+                
+                const linkChapterId = this.extractChapterIdFromUrl(href);
+                if (!linkChapterId || linkChapterId === currentChapterId) return null;
+                
+                return {
+                    url: new URL(href, this.url).href,
+                    text: link.textContent?.trim() || '',
+                    chapterId: linkChapterId
+                };
+            })
+            .filter(Boolean)
+            .sort((a, b) => a!.chapterId - b!.chapterId);
+        
+        if (!chapterLinks.length) return null;
+        
+        if (isNext) {
+            // Find next chapter (higher ID)
+            const nextLink = chapterLinks.find(link => link!.chapterId > currentChapterId);
+            return nextLink?.url || null;
+        } else {
+            // Find previous chapter (lower ID) 
+            const prevLink = chapterLinks.reverse().find(link => link!.chapterId < currentChapterId);
+            return prevLink?.url || null;
+        }
+    };
+    
+    private extractChapterIdFromUrl = (url: string): number => {
+        const match = url.match(/\/novel\/(\d+)/);
+        return match ? parseInt(match[1], 10) : 0;
+    };
+    
+    getNextLink = (): string | null => this.getLinkByDirection(true);
+    getPrevLink = (): string | null => this.getLinkByDirection(false);
+}
+
 const getAdapter = (url: string, doc: Document): BaseAdapter | null => {
     if (url.includes('kakuyomu.jp')) return new KakuyomuAdapter(url, doc);
