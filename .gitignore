.playwright-mcp/

# Source material: photos/scans of physical chant books + Google Takeout zips.
# Kept OUT of git (binary, ~74M; would permanently bloat history and jpg/zip are
# not routed through LFS). Lives on disk only; transcriptions belong in data/liturgy/.
/chants/
.vercel

# Local pipeline outputs (contain full copyrighted prose — never commit)
out/
